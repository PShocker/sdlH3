include "Client.fbs";
include "Server.fbs";

// 联合体：包含所有消息类型
union NetPayload {
    ClientHeartbeat,
    ClientLogin,
    ClientInScene,
    ClientOutScene,
    ServerHeartbeat,
    ServerLogin,
    ServerInScene,
    ServerOutScene,
}
// 统一的网络包（最外层包装）
table NetPacket {
    payload:NetPayload;          // 实际数据
}

root_type NetPacket;